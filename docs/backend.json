
{
  "entities": {
    "User": {
      "title": "Utilisateur",
      "description": "Profil utilisateur du système ACADEX (Identifiants DIR-, ENS-, ELV-)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["DIRECTOR", "TEACHER", "STUDENT_PARENT"] },
        "password": { "type": "string" },
        "schoolName": { "type": "string" },
        "subject": { "type": "string" },
        "secretQuestion": { "type": "string" },
        "secretAnswer": { "type": "string" },
        "status": { "type": "string", "enum": ["Actif", "Inactif", "Suspendu"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "role", "password"]
    },
    "SchoolConfig": {
      "title": "Configuration École",
      "description": "Paramètres globaux et identité de l'établissement",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slogan": { "type": "string" },
        "academicYear": { "type": "string" },
        "address": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "logoUrl": { "type": "string" }
      }
    },
    "AuditLog": {
      "title": "Journal d'Audit",
      "description": "Enregistrement des événements de sécurité et connexions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "action": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "ip": { "type": "string" },
        "details": { "type": "string" }
      },
      "required": ["userId", "action", "timestamp"]
    },
    "Student": {
      "title": "Registre Élève",
      "description": "Information sur un élève pré-provisionné ou actif",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "gradeLevel": { "type": "string" },
        "status": { "type": "string", "enum": ["En attente", "Actif", "Suspendu"] },
        "paymentStatus": { "type": "string", "enum": ["Payé", "Partiel", "Impayé"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "activatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "gradeLevel", "status"]
    },
    "Subject": {
      "title": "Matière",
      "description": "Configuration des matières et coefficients",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "coefficient": { "type": "number" },
        "level": { "type": "string" }
      },
      "required": ["name", "coefficient"]
    },
    "Grade": {
      "title": "Note",
      "description": "Évaluation d'un élève dans une matière",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "subjectId": { "type": "string" },
        "subjectName": { "type": "string" },
        "value": { "type": "number" },
        "term": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string", "enum": ["Brouillon", "Confirmé"] },
        "updatedBy": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "subjectId", "value"]
    },
    "Payment": {
      "title": "Paiement",
      "description": "Historique des versements de scolarité",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "type": { "type": "string" },
        "status": { "type": "string", "enum": ["Payé", "Partiel"] }
      },
      "required": ["studentId", "amount", "date"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/backend/entities/User",
      "description": "Profils des utilisateurs et comptes activés"
    },
    "/auditLogs/{logId}": {
      "schema": "#/backend/entities/AuditLog",
      "description": "Historique des accès et sécurité"
    },
    "/students/{studentId}": {
      "schema": "#/backend/entities/Student",
      "description": "Base de données des élèves (Source pour activation)"
    },
    "/subjects/{subjectId}": {
      "schema": "#/backend/entities/Subject",
      "description": "Configuration académique"
    },
    "/grades/{gradeId}": {
      "schema": "#/backend/entities/Grade",
      "description": "Notes des élèves"
    },
    "/payments/{paymentId}": {
      "schema": "#/backend/entities/Payment",
      "description": "Versements de scolarité"
    },
    "/config/school": {
      "schema": "#/backend/entities/SchoolConfig",
      "description": "Configuration globale de l'école"
    }
  }
}
